{
  "compilerOptions": {
    "types": ["node", "jest"],

    "target": "ES2024",
    "module": "nodenext",
    "moduleResolution": "nodenext",

    // Links e Emissão
    "outDir": "./dist",
    "declaration": true,
    "sourceMap": true,
    "incremental": true,
    "removeComments": true,

    // Decorators (Se você usa NestJS / TypeORM)
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,

    // Qualidade de Código e Checagem
    "skipLibCheck": true,
    "strictNullChecks": true,
    "forceConsistentCasingInFileNames": true,
    "noImplicitAny": false,
    "strictBindCallApply": false,
    "noFallthroughCasesInSwitch": false
  }
}
